# ChatOut Backend — Development Environment Variables
# Copy this to .env and fill in your values.
# DO NOT COMMIT .env TO GIT (.gitignore already covers it).

PORT=3021
NODE_ENV=development

# =============================================================================
# AI Gateway — DeepSeek V4 Flash (exclusive)
# Set these to enable the chatbot.
# The same key is used for dev + production. Keep it server-side only.
# =============================================================================
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_MS=25000

# Legacy aliases kept so older deploys keep working
AI_GATEWAY_URL=
AI_API_KEY=

# =============================================================================
# Tool-call loop cap — DeepSeek can call tools for up to N rounds before
# forcing a final answer. 5 is a hard ceiling to prevent infinite loops.
# =============================================================================
MAX_TOOL_ROUNDS=5

# =============================================================================
# Admin endpoints — bearer token for /api/admin/* (interactions DB browser,
# stats, etc.). Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store ONLY in .env on the server — never in source.
# Without ADMIN_API_KEY set, all /api/admin/* endpoints return 503.
# =============================================================================
ADMIN_API_KEY=

# Rate limiting on /api/chat (per session+IP, sliding window)
CHAT_RATE_LIMIT_MAX=30
CHAT_RATE_LIMIT_WINDOW_MS=60000

# Nomba payment gateway (OAuth client_credentials flow)
# Get these from your Nomba dashboard (https://dashboard.nomba.com).
# NOMBA_PRIVATE_KEY is the OAuth client_secret (there is no raw-key signing).
# Sandbox base URL: https://sandbox.nomba.com  |  Production: https://api.nomba.com
NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_PRIVATE_KEY=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SECRET=
NOMBA_BASE_URL=https://sandbox.nomba.com

# Flutterwave — used ONLY for read-only bank-account name resolution (KYC).
# Get these from your Flutterwave dashboard (https://dashboard.flutterwave.com).
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
FLW_BASE_URL=https://api.flutterwave.com

# Partner auth — shared secret for server-to-server calls to
# POST /api/merchants/register. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PARTNER_API_KEY=

# Merchant registry labels (optional; host-agnostic defaults shown).
# MERCHANT_PROVIDER is stored on each merchant row; MERCHANT_REF_PREFIX is the
# prefix for the Nomba accountRef (must keep the final ref >= 16 chars).
MERCHANT_PROVIDER=host
MERCHANT_REF_PREFIX=merchant

# Dynamic catalog provider — the host endpoint ChatOut fetches products from.
# Must return the ChatOut Catalog Protocol shape { shop, products }.
# See docs/INTEGRATION_GUIDE.md.
CATALOG_PROVIDER_URL=

# Public base URL used to build customer links (#/s/<slug>) and Nomba callbacks.
APP_PUBLIC_URL=https://chatout.obenitsolutions.com